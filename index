function tKey(r){return r.pos==='CERA SHOP'?r.title+' - CERA':r.title;}
function proc(data){
  const tot={},dtf={},pos={},ctr={},sub={},sr={};
  data.forEach(r=>{
    const k=tKey(r);
    if(!tot[k])tot[k]={t:0,r:0};tot[k].t+=r.tickets;tot[k].r+=r.price;
    if(!dtf[r.dtf])dtf[r.dtf]={};
    if(!dtf[r.dtf][k])dtf[r.dtf][k]={t:0,r:0};
    dtf[r.dtf][k].t+=r.tickets;dtf[r.dtf][k].r+=r.price;
    if(!pos[r.pos])pos[r.pos]=0;pos[r.pos]+=r.tickets;
    if(!ctr[r.country])ctr[r.country]=0;ctr[r.country]+=r.tickets;
    const sk=r.pos==='CERA SHOP'?'Cera - '+r.subtitle:r.subtitle;
    if(!sub[k])sub[k]={};if(!sub[k][sk])sub[k][sk]=0;sub[k][sk]+=r.tickets;
    if(!sr[r.subtitle])sr[r.subtitle]=0;sr[r.subtitle]+=r.tickets;
  });
