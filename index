      <td>${f25?pO(t26,f25):'—'}</td>
      <td class="t25">${f25&&t25wv?pO(t25wv,f25):'—'}</td>
      <td>${wave?`<span class="badge" style="color:${Y26};border-color:${Y26}">${wave}</span>`:'—'}</td>
      <td class="t26">${ws?N(ws):'—'}</td><td>${wq?N(wq):'—'}</td>
      <td>${ws&&wq?bar(ws/wq*100,Y26):'—'}</td><td>${wq?N(wq-ws):'—'}</td>
    </tr>`;
  }).join('');
  const tot=`<tr><td>Total</td><td class="t26">${N(totT26)}</td><td class="t25">${N(totT25)}</td><td class="${dc(totT26,totT25)}">${ds(totT26,totT25)}</td><td>${N(totCap)}</td><td>${N(totCap-totT26)}</td><td>${bar(totT26/totCap*100)}</td><td class="t25">${N(totF25)}</td><td>${pO(totT26,totF25)}</td><td class="t25">${pO(totT25,totF25)}</td><td colspan="5"></td></tr>`;
  document.getElementById('tbl-status').innerHTML=th+'<tbody>'+body+tot+'</tbody>';

  const k26=Object.keys(T26).filter(k=>T26[k].t>0);
  mk('c-pie','doughnut',k26.map(k=>k.replace(' (Public holiday)','').replace(' (Saturday, Sunday, Monday)','')),
    [{data:k26.map(k=>T26[k].t),backgroundColor:k26.map(k=>DC[k]||'#888'),borderWidth:1,borderColor:'#f7f7f5'}],
    {plugins:{legend:{position:'right'}},cutout:'60%'});
  const days=['Saturday','Sunday','Monday (Public holiday)'];
  mk('c-cera','bar',['Sat','Sun','Mon'],[
    {label:'General',data:days.map(d=>(T26[d]||{t:0}).t),backgroundColor:days.map(d=>DC[d]),stack:'a'},
    {label:'CERA',data:days.map(d=>(T26[d+' - CERA']||{t:0}).t),backgroundColor:['#60a5fa','#4ade80','#fb923c'],stack:'a'}
  ],{scales:{x:{stacked:true},y:{stacked:true}},plugins:{legend:{position:'top'}}});
}

// ── REVENUE ──────────────────────────────────
function bRev(){
  const tt26=Object.values(T26).reduce((s,v)=>s+v.t,0);
  const tr26=Object.values(T26).reduce((s,v)=>s+v.r,0);
  const tr25f=Object.values(T25).reduce((s,v)=>s+v.r,0);
  const minDTF=Math.min(...D26.map(r=>r.dtf));
  let tr25w=0;D25.forEach(r=>{if(r.dtf>=minDTF)tr25w+=r.price;});
  const tt25f=Object.values(T25).reduce((s,v)=>s+v.t,0);

  document.getElementById('krow-rev').innerHTML=[
    {l:'Revenue 2026 (D-'+minDTF+' to now)',v:EU(tr26),s:N(tt26)+' tickets sold',c:Y26},
    {l:'Revenue 2025 @same period',v:EU(tr25w),s:'D-'+minDTF+' onwards',c:Y25},
    {l:'2026 vs 2025 @same period',v:ds(tr26,tr25w),s:'revenue comparison',c:tr26>=tr25w?'#166534':'#991b1b'},
    {l:'2025 full season revenue',v:EU(tr25f),s:N(tt25f)+' tickets',c:Y25},
    {l:'2026 vs 2025 full season',v:pO(tr26,tr25f),s:'% of 2025 total reached',c:'#78716c'},
  ].map(k=>`<div class="kpi" style="--kc:${k.c}"><div class="klbl">${k.l}</div><div class="kval">${k.v}</div><div class="ksub">${k.s}</div></div>`).join('');

  const dtfs=DTFS(185),lbl=dtfs.map(d=>'D-'+d);
  mk('c-rcum-all','line',lbl,[lDS('2026',nE(cs(trA(DTF26,dtfs))),Y26,Y26b),lDS('2025',nE(cs(trA(DTF25,dtfs))),Y25,Y25b)],{plugins:{legend:{position:'top'}},yS:{ticks:{callback:v=>'€'+(v/1000).toFixed(0)+'k'}}});
  mk('c-rday-all','bar',lbl,[{label:'2026',data:nE(trA(DTF26,dtfs)),backgroundColor:'rgba(217,119,6,.65)',stack:'a'},{label:'2025',data:nE(trA(DTF25,dtfs)),backgroundColor:'rgba(37,99,235,.4)',stack:'b'}],{plugins:{legend:{position:'top'}},yS:{ticks:{callback:v=>'€'+(v/1000).toFixed(0)+'k'}}});
  [['sat','Saturday'],['sun','Sunday'],['mon','Monday (Public holiday)']].forEach(([s,k])=>{
    mk('c-rcum-'+s,'line',lbl,[lDS('2026',nE(cs(rA(DTF26,k,dtfs))),Y26,Y26b),lDS('2025',nE(cs(rA(DTF25,k,dtfs))),Y25,Y25b)],{plugins:{legend:{position:'top'}},yS:{ticks:{callback:v=>'€'+(v/1000).toFixed(0)+'k'}}});
  });

  const tRevR=tr26;
  const rows=Object.entries(T26).sort((a,b)=>b[1].r-a[1].r).map(([k,v])=>`<tr>
    <td><span class="dot" style="background:${DC[k]||'#888'}"></span>${k}</td>
    <td class="t26">${N(v.t)}</td><td class="t26">${EU(v.r)}</td><td class="t26">${EU(v.r/v.t)}</td>
    <td>${bar(v.r/tRevR*100,DC[k]||Y26)}</td>
    <td class="t25">${EU((T25[k]||T25[k.replace('Saturday, Sunday, Monday','Friday, Saturday, Sunday, Monday')]||{r:0}).r)}</td>
  </tr>`).join('');
  document.getElementById('tbl-rev').innerHTML=`<thead><tr><th>Ticket type</th><th>Tickets (2026)</th><th>Revenue (2026)</th><th>Avg price</th><th>% of total</th><th>Revenue (2025 full)</th></tr></thead><tbody>${rows}<tr><td>Total</td><td class="t26">${N(tt26)}</td><td class="t26">${EU(tr26)}</td><td class="t26">${EU(tr26/tt26)}</td><td>100%</td><td class="t25">${EU(tr25f)}</td></tr></tbody>`;
}

// ── DAILY ────────────────────────────────────
function bDay(){
  const dtfs=DTFS(185),lbl=dtfs.map(d=>'D-'+d);
  // Past 10 days (lowest 10 DTF values = most recent)
  const d10=Object.keys(DTF26).map(Number).sort((a,b)=>a-b).slice(0,10);
  const l10=d10.map(d=>'D-'+d);
  const tK=['Saturday','Sunday','Monday (Public holiday)','Combi (Saturday, Sunday, Monday)'];
  const tL=['Saturday','Sunday','Monday','Combi'];
  const tC=['#1d4ed8','#15803d','#c2410c','#6d28d9'];
  mk('c-d10','bar',l10,tK.map((k,i)=>({label:tL[i],data:d10.map(d=>DTF26[d]&&DTF26[d][k]?DTF26[d][k].t:0),backgroundColor:tC[i],stack:'s'})),{scales:{x:{stacked:true},y:{stacked:true}},plugins:{legend:{position:'top'}}});
  mk('c-dall','line',lbl,[lDS('2026',nE(tA(DTF26,dtfs)),Y26,Y26b),lDS('2025',nE(tA(DTF25,dtfs)),Y25,Y25b)],{plugins:{legend:{position:'top'}}});
  [['dsat','Saturday'],['dsun','Sunday'],['dmon','Monday (Public holiday)']].forEach(([s,k])=>{
    mk('c-'+s,'line',lbl,[lDS('2026',nE(dA(DTF26,k,dtfs)),Y26,Y26b),lDS('2025',nE(dA(DTF25,k,dtfs)),Y25,Y25b)],{plugins:{legend:{position:'top'}}});
  });
}

// ── CUMULATIVE ───────────────────────────────
function bCum(){
  const dtfs=DTFS(185),lbl=dtfs.map(d=>'D-'+d);
  function pair(id26,id25,fn26,fn25,isRev){
    const o=isRev?{plugins:{legend:{position:'top'}},yS:{ticks:{callback:v=>'€'+(v/1000).toFixed(0)+'k'}}}:{plugins:{legend:{position:'top'}}};
    mk(id26,'line',lbl,[lDS('2026',nE(cs(fn26(DTF26,dtfs))),Y26,Y26b),lDS('2025',nE(cs(fn25(DTF25,dtfs))),Y25,Y25b)],o);
  }
  pair('c-ct-all','c-cr-all',(o,d)=>tA(o,d),(o,d)=>tA(o,d),false);
  pair('c-cr-all','c-cr-all',(o,d)=>trA(o,d),(o,d)=>trA(o,d),true);
  // overwrite with correct
  mk('c-ct-all','line',lbl,[lDS('2026',nE(cs(tA(DTF26,dtfs))),Y26,Y26b),lDS('2025',nE(cs(tA(DTF25,dtfs))),Y25,Y25b)],{plugins:{legend:{position:'top'}}});
  mk('c-cr-all','line',lbl,[lDS('2026',nE(cs(trA(DTF26,dtfs))),Y26,Y26b),lDS('2025',nE(cs(trA(DTF25,dtfs))),Y25,Y25b)],{plugins:{legend:{position:'top'}},yS:{ticks:{callback:v=>'€'+(v/1000).toFixed(0)+'k'}}});
  [['sat','Saturday'],['sun','Sunday'],['mon','Monday (Public holiday)']].forEach(([s,k])=>{
    mk('c-ct-'+s,'line',lbl,[lDS('2026',nE(cs(dA(DTF26,k,dtfs))),Y26,Y26b),lDS('2025',nE(cs(dA(DTF25,k,dtfs))),Y25,Y25b)],{plugins:{legend:{position:'top'}}});
    mk('c-cr-'+s,'line',lbl,[lDS('2026',nE(cs(rA(DTF26,k,dtfs))),Y26,Y26b),lDS('2025',nE(cs(rA(DTF25,k,dtfs))),Y25,Y25b)],{plugins:{legend:{position:'top'}},yS:{ticks:{callback:v=>'€'+(v/1000).toFixed(0)+'k'}}});
  });
}

// ── WAVES ────────────────────────────────────
function bWav(){
  const ROWS=[
    {l:'Saturday',k:'Saturday',c:'#1d4ed8'},{l:'Sunday',k:'Sunday',c:'#15803d'},
    {l:'Monday',k:'Monday (Public holiday)',c:'#c2410c'},
    {l:'Combi',k:'Combi (Saturday, Sunday, Monday)',c:'#6d28d9'},
    {l:'Sat – CERA',k:'Saturday - CERA',c:'#60a5fa'},
    {l:'Sun – CERA',k:'Sunday - CERA',c:'#4ade80'},
    {l:'Mon – CERA',k:'Monday (Public holiday) - CERA',c:'#fb923c'}
  ];
  function ws(k,wave){return D26.filter(x=>tKey(x)===k&&(x.pos==='CERA SHOP'?'Cera - '+x.subtitle:x.subtitle)===wave).reduce((s,x)=>s+x.tickets,0);}
  const th=`<thead><tr><th>Ticket type</th><th>Current wave</th><th class="t26">Sold in wave</th><th>Wave quota</th><th>% quota</th><th>Left in wave</th><th class="t26">Total sold</th><th>Total capacity</th><th>% cap</th><th>Left to cap</th></tr></thead>`;
  const body=ROWS.map(r=>{
    const t=(T26[r.k]||{t:0}).t;const cap=CAP[r.k]||0;
    const wave=CW[r.k];const wq=wave&&WAVE_CFG[r.k]?WAVE_CFG[r.k][wave]||0:0;const sold=wave?ws(r.k,wave):0;
    return `<tr><td><span class="dot" style="background:${r.c}"></span>${r.l}</td>
      <td>${wave?`<span class="badge" style="color:${Y26};border-color:${Y26}">${wave}</span>`:'—'}</td>
      <td class="t26">${sold?N(sold):'—'}</td><td>${wq?N(wq):'—'}</td>
      <td>${sold&&wq?bar(sold/wq*100,Y26):'—'}</td><td>${wq?N(wq-sold):'—'}</td>
      <td class="t26">${N(t)}</td><td>${cap?N(cap):'—'}</td>
      <td>${cap?bar(t/cap*100):'—'}</td><td>${cap?N(cap-t):'—'}</td></tr>`;
  }).join('');
  document.getElementById('tbl-wav').innerHTML=th+'<tbody>'+body+'</tbody>';

  const wR=ROWS.filter(r=>CW[r.k]);
  const fills=wR.map(r=>{const wave=CW[r.k];const wq=WAVE_CFG[r.k]?WAVE_CFG[r.k][wave]||0:0;const sold=ws(r.k,wave);return wq?Math.round(sold/wq*100):0;});
  const quotas=wR.map(r=>{const wave=CW[r.k];return WAVE_CFG[r.k]?WAVE_CFG[r.k][wave]||0:0;});
  const solds=wR.map(r=>ws(r.k,CW[r.k]));
  mk('c-wf','bar',wR.map(r=>r.l),[{label:'% quota sold',data:fills,backgroundColor:wR.map(r=>r.c)}],{plugins:{legend:{display:false}},yS:{max:100,ticks:{callback:v=>v+'%'}}});
  mk('c-wb','bar',wR.map(r=>r.l),[{label:'Sold in wave',data:solds,backgroundColor:Y26},{label:'Quota',data:quotas,backgroundColor:'rgba(0,0,0,.07)',borderColor:'rgba(37,99,235,.4)',borderWidth:1}],{plugins:{legend:{position:'top'}}});

  const cth=`<thead><tr><th>Ticket type</th><th class="t26">Sold</th><th>Capacity</th><th>Left</th><th>% filled</th></tr></thead>`;
  const cr=ROWS.map(r=>{const t=(T26[r.k]||{t:0}).t;const cap=CAP[r.k]||0;return `<tr><td><span class="dot" style="background:${r.c}"></span>${r.l}</td><td class="t26">${N(t)}</td><td>${cap?N(cap):'—'}</td><td>${cap?N(cap-t):'—'}</td><td>${cap?bar(t/cap*100):'—'}</td></tr>`;}).join('');
  const tS=ROWS.reduce((s,r)=>s+(T26[r.k]||{t:0}).t,0);const tC=ROWS.reduce((s,r)=>s+(CAP[r.k]||0),0);
  document.getElementById('tbl-cap').innerHTML=cth+'<tbody>'+cr+`<tr><td>Total</td><td class="t26">${N(tS)}</td><td>${N(tC)}</td><td>${N(tC-tS)}</td><td>${bar(tS/tC*100)}</td></tr></tbody>`;
}

// ── ATTENDANCE ───────────────────────────────
function bAtt(){
  const days=[{k:'Saturday',l:'Saturday',c:'#1d4ed8'},{k:'Sunday',l:'Sunday',c:'#15803d'},{k:'Monday (Public holiday)',l:'Monday',c:'#c2410c'}];
  const minDTF=Math.min(...D26.map(r=>r.dtf));
  let t25w={};D25.forEach(r=>{if(r.dtf>=minDTF){const k=tKey(r);if(!t25w[k])t25w[k]=0;t25w[k]+=r.tickets;}});
  function dT26(k){return(T26[k]||{t:0}).t+(T26[k+' - CERA']||{t:0}).t;}
  function dT25(k){return(t25w[k]||0)+(t25w[k+' - CERA']||0);}
  const th=`<thead><tr><th>Day</th><th class="t26">Tickets 2026</th><th class="t25">2025 @same DTF</th><th>Δ</th><th>Guests*</th><th>Sales+Guests</th><th>No-show*</th><th class="t26">2026 Att. est.</th><th class="t25">2025 Actual</th><th>2026/2025</th></tr></thead>`;
  let tS=0,tG=0,tA26=0,tA25=0;
  const body=days.map(d=>{
    const s=dT26(d.k);const s25=dT25(d.k);const g=GUESTS[d.k]||0;
    const tot=s+g;const att=Math.round(tot*(1-NO_SHOW));const a25=ATT25[d.k];
    tS+=s;tG+=g;tA26+=att;tA25+=a25;
    return `<tr><td><span class="dot" style="background:${d.c}"></span>${d.l}</td><td class="t26">${N(s)}</td><td class="t25">${N(s25)}</td><td class="${dc(s,s25)}">${ds(s,s25)}</td><td>${N(g)}</td><td>${N(tot)}</td><td>${NO_SHOW*100}%</td><td class="t26">${N(att)}</td><td class="t25">${N(a25)}</td><td class="${dc(att,a25)}">${pO(att,a25)}</td></tr>`;
  }).join('');
  const totRow=`<tr><td>Total</td><td class="t26">${N(tS)}</td><td class="t25">—</td><td>—</td><td>${N(tG)}</td><td>${N(tS+tG)}</td><td>${NO_SHOW*100}%</td><td class="t26">${N(tA26)}</td><td class="t25">${N(tA25)}</td><td class="${dc(tA26,tA25)}">${pO(tA26,tA25)}</td></tr>`;
  document.getElementById('tbl-att').innerHTML=th+'<tbody>'+body+totRow+'</tbody>';
  const cE=Object.entries(CTR26).sort((a,b)=>b[1]-a[1]).slice(0,10);
  mk('c-ctr','bar',cE.map(e=>e[0]),[{data:cE.map(e=>e[1]),backgroundColor:Y26}],{indexAxis:'y',plugins:{legend:{display:false}}});
  const pE=Object.entries(POS26).sort((a,b)=>b[1]-a[1]);
  mk('c-pos','bar',pE.map(e=>e[0]),[{data:pE.map(e=>e[1]),backgroundColor:Y26}],{indexAxis:'y',plugins:{legend:{display:false}}});
}

// ── BREAKDOWN ────────────────────────────────
function bBrk(){
  function subPie(id,k){
    const subs=SUB26[k]||{};
    const sorted=WAVE_ORDER.filter(w=>subs[w]>0).concat(Object.keys(subs).filter(w=>!WAVE_ORDER.includes(w)&&subs[w]>0));
    mk(id,'doughnut',sorted,[{data:sorted.map(w=>subs[w]),backgroundColor:sorted.map(w=>SC[w]||'#888'),borderWidth:1,borderColor:'#f7f7f5'}],{plugins:{legend:{position:'bottom',labels:{boxWidth:8,padding:5,font:{size:9}}}},cutout:'55%'});
  }
  subPie('c-bsat','Saturday');subPie('c-bsun','Sunday');subPie('c-bmon','Monday (Public holiday)');
  const wCats=['Presale','Early Bird','Regular','Final Wave','Kids'];
  mk('c-wsplit','bar',wCats,[{label:'2026',data:wCats.map(k=>SR26[k]||0),backgroundColor:Y26},{label:'2025',data:wCats.map(k=>SR25[k]||0),backgroundColor:Y25}],{plugins:{legend:{position:'top'}}});
  const minDTF=Math.min(...D26.map(r=>r.dtf));
  let t25w={};D25.forEach(r=>{if(r.dtf>=minDTF){const k=tKey(r);if(!t25w[k])t25w[k]=0;t25w[k]+=r.tickets;}});
  const cK=['Saturday','Sunday','Monday (Public holiday)','Combi (Saturday, Sunday, Monday)'];
  mk('c-tcomp','bar',['Saturday','Sunday','Monday','Combi'],[
    {label:'2026 now',data:cK.map(k=>(T26[k]||{t:0}).t),backgroundColor:Y26},
    {label:'2025 @same DTF',data:cK.map(k=>t25w[k]||t25w[k.replace('Saturday, Sunday, Monday','Friday, Saturday, Sunday, Monday')]||0),backgroundColor:Y25}
  ],{plugins:{legend:{position:'top'}}});
}

// ── LIVE REFRESH ─────────────────────────────
async function liveRefresh(){
  if(!API){alert('Live API not set. Paste Apps Script URL into API constant in the code.');return;}
  const btn=document.querySelector('.rbtn');btn.textContent='↻ Loading…';btn.disabled=true;
  try{
    const resp=await fetch(API+'?t='+Date.now());
    if(!resp.ok)throw new Error('HTTP '+resp.status);
    const j=await resp.json();if(j.error)throw new Error(j.error);
    const fresh=j.data.map(r=>({
      date:r['Date of order']||r.date||'',
      dtf:parseInt(r['Days to festival']||r.dtf)||0,
      pos:r['Point of Sale Title']||r.pos||'',
      title:r['Product Title']||r.title||'',
      subtitle:r['Product Subtitle']||r.subtitle||'',
      tickets:parseInt(r['Number of tickets sold']||r.tickets)||0,
      price:parseFloat(String(r['Total price']||r.price||0).replace(',','.'))||0,
      country:r['Country']||r.country||''
    })).filter(r=>r.tickets>0&&r.dtf>=0);
    loadData(fresh,D25);buildAll();
    btn.textContent='✓ Updated!';setTimeout(()=>{btn.textContent='↻ Live refresh';btn.disabled=false;},2500);
  }catch(e){alert('Refresh failed: '+e.message);btn.textContent='↻ Live refresh';btn.disabled=false;}
}

// ── TAB SWITCH ───────────────────────────────
function ST(n,el){
  document.querySelectorAll('.sec').forEach(s=>s.classList.remove('on'));
  document.querySelectorAll('.nt').forEach(t=>t.classList.remove('on'));
  document.getElementById('s-'+n).classList.add('on');el.classList.add('on');
}

function buildAll(){bOv();bRev();bDay();bCum();bWav();bAtt();bBrk();}

loadData(E26,E25);setFresh();buildAll();
</script>
