<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jazz Middelheim 2026 — Ticket Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#f7f7f5;--sf:#fff;--sf2:#f0efeb;--bd:#e2ddd8;
  --tx:#1c1917;--mu:#78716c;
  --y26:#d97706;--y26b:rgba(217,119,6,.1);
  --y25:#2563eb;--y25b:rgba(37,99,235,.09);
  --pos:#166534;--neg:#991b1b;--r:8px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--tx);font-family:'Sora',sans-serif;font-size:13px;line-height:1.5;}
/* HEADER */
.hdr{background:var(--sf);border-bottom:1px solid var(--bd);padding:11px 22px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;box-shadow:0 1px 3px rgba(0,0,0,.05);}
.hdr-l{display:flex;align-items:center;gap:10px;}
.logo{width:28px;height:28px;border-radius:6px;background:linear-gradient(135deg,#d97706,#f59e0b);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:11px;font-family:'JetBrains Mono',monospace;}
.hdr h1{font-size:14px;font-weight:600;}
.hdr-sub{font-size:10px;color:var(--mu);font-family:'JetBrains Mono',monospace;margin-top:1px;}
.hdr-r{display:flex;align-items:center;gap:7px;flex-wrap:wrap;}
.pill{font-family:'JetBrains Mono',monospace;font-size:10px;padding:3px 8px;border-radius:4px;border:1px solid var(--bd);background:var(--sf2);color:var(--mu);}
.pill.p26{background:rgba(217,119,6,.1);border-color:rgba(217,119,6,.3);color:var(--y26);}
.pill.p25{background:rgba(37,99,235,.1);border-color:rgba(37,99,235,.3);color:var(--y25);}
.rbtn{font-family:'JetBrains Mono',monospace;font-size:10px;padding:4px 11px;border-radius:5px;background:var(--y26);color:#fff;border:none;cursor:pointer;}
.rbtn:hover{opacity:.85;}
/* NAV */
.nav{background:var(--sf);border-bottom:1px solid var(--bd);display:flex;padding:0 22px;overflow-x:auto;}
.nt{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.05em;text-transform:uppercase;padding:10px 13px;cursor:pointer;color:var(--mu);border-bottom:2px solid transparent;border:none;background:none;white-space:nowrap;}
.nt:hover{color:var(--tx);}.nt.on{color:var(--y26);border-bottom:2px solid var(--y26);font-weight:600;}
/* MAIN */
.main{padding:18px 22px;max-width:1800px;}
.sec{display:none;}.sec.on{display:block;}
/* KPI */
.krow{display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap;}
.kpi{background:var(--sf);border:1px solid var(--bd);border-radius:var(--r);padding:12px 14px;flex:1;min-width:130px;position:relative;overflow:hidden;}
.kpi:after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--kc,var(--y26));}
.klbl{font-size:10px;color:var(--mu);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;}
.kval{font-size:20px;font-weight:700;line-height:1.1;}
.ksub{font-size:10px;color:var(--mu);margin-top:2px;font-family:'JetBrains Mono',monospace;}
/* GRIDS */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:14px;}
.g1{margin-bottom:14px;}
/* CARD */
.card{background:var(--sf);border:1px solid var(--bd);border-radius:var(--r);padding:14px;}
.ct{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--mu);margin-bottom:9px;display:flex;align-items:center;gap:5px;flex-wrap:wrap;}
.yl{display:inline-flex;align-items:center;gap:3px;font-size:9px;font-family:'JetBrains Mono',monospace;color:var(--mu);}
.yl-l{width:16px;height:2px;border-radius:1px;display:inline-block;}
/* TABLES */
.tw{background:var(--sf);border:1px solid var(--bd);border-radius:var(--r);overflow:hidden;margin-bottom:14px;}
.th{padding:9px 13px;border-bottom:1px solid var(--bd);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--mu);}
table{width:100%;border-collapse:collapse;}
thead th{font-family:'JetBrains Mono',monospace;font-size:10px;text-transform:uppercase;letter-spacing:.04em;color:var(--mu);padding:7px 10px;text-align:right;background:var(--sf2);border-bottom:1px solid var(--bd);white-space:nowrap;}
thead th:first-child{text-align:left;}
tbody td{padding:7px 10px;text-align:right;border-bottom:1px solid rgba(226,221,216,.7);font-family:'JetBrains Mono',monospace;font-size:11px;}
tbody td:first-child{text-align:left;font-family:'Sora',sans-serif;font-weight:500;font-size:12px;}
tbody tr:last-child td{border-bottom:none;background:rgba(217,119,6,.04);font-weight:600;}
tbody tr:hover td{background:rgba(0,0,0,.012);}
.bw{display:inline-flex;align-items:center;gap:4px;}
.bbg{width:42px;height:3px;background:var(--bd);border-radius:2px;display:inline-block;vertical-align:middle;overflow:hidden;}
.bf{height:100%;border-radius:2px;display:block;}
.dot{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:5px;vertical-align:middle;}
.badge{font-family:'JetBrains Mono',monospace;font-size:9px;padding:1px 5px;border-radius:3px;border:1px solid;}
.t26{color:var(--y26);font-weight:600;}.t25{color:var(--y25);}
.pos{color:var(--pos);}.neg{color:var(--neg);}
.note{font-size:10px;color:var(--mu);padding:6px 13px;font-style:italic;border-top:1px solid var(--bd);}
@media(max-width:900px){.g2,.g3{grid-template-columns:1fr;}.kpi{min-width:44%;}}
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-l">
    <div class="logo">JM</div>
    <div>
      <h1>Jazz Middelheim — Ticket Dashboard</h1>
      <div class="hdr-sub" id="fresh-bar">Loading…</div>
    </div>
  </div>
  <div class="hdr-r">
    <span class="pill p26">■ 2026 = Amber</span>
    <span class="pill p25">■ 2025 = Blue</span>
    <span class="pill" id="dtf-pill">D-?</span>
    <button class="rbtn" onclick="liveRefresh()">↻ Live refresh</button>
  </div>
</div>

<div class="nav">
  <button class="nt on" onclick="ST('ov',this)">Overview</button>
  <button class="nt"    onclick="ST('rev',this)">Revenue</button>
  <button class="nt"    onclick="ST('day',this)">Daily Sales</button>
  <button class="nt"    onclick="ST('cum',this)">Cumulative</button>
  <button class="nt"    onclick="ST('wav',this)">Waves &amp; Capacity</button>
  <button class="nt"    onclick="ST('att',this)">Attendance</button>
  <button class="nt"    onclick="ST('brk',this)">Breakdown</button>
</div>

<div class="main">

<!-- OVERVIEW -->
<div class="sec on" id="s-ov">
  <div class="krow" id="krow-ov"></div>
  <div class="tw"><div class="th">Status per ticket type — 2026 vs 2025, capacity &amp; wave progress</div><table id="tbl-status"></table></div>
  <div class="g2">
    <div class="card"><div class="ct">Tickets by type — 2026 YTD</div><canvas id="c-pie" height="200"></canvas></div>
    <div class="card"><div class="ct">CERA SHOP vs General — by day (2026)</div><canvas id="c-cera" height="200"></canvas></div>
  </div>
</div>

<!-- REVENUE -->
<div class="sec" id="s-rev">
  <div class="krow" id="krow-rev"></div>
  <div class="g2">
    <div class="card"><div class="ct">Gross cumulative revenue — all <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>2026 <span class="yl-l" style="background:var(--y25)"></span>2025</span></div><canvas id="c-rcum-all" height="210"></canvas></div>
    <div class="card"><div class="ct">Daily revenue — all <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>2026 <span class="yl-l" style="background:var(--y25)"></span>2025</span></div><canvas id="c-rday-all" height="210"></canvas></div>
  </div>
  <div class="g3">
    <div class="card"><div class="ct">Cumul. revenue — Saturday <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-rcum-sat" height="190"></canvas></div>
    <div class="card"><div class="ct">Cumul. revenue — Sunday <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-rcum-sun" height="190"></canvas></div>
    <div class="card"><div class="ct">Cumul. revenue — Monday <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-rcum-mon" height="190"></canvas></div>
  </div>
  <div class="tw"><div class="th">Revenue by ticket type — 2026 vs 2025 full season</div><table id="tbl-rev"></table></div>
</div>

<!-- DAILY -->
<div class="sec" id="s-day">
  <div class="card g1"><div class="ct">Past 10 days — tickets by type (2026, stacked bar)</div><canvas id="c-d10" height="150"></canvas></div>
  <div class="card g1"><div class="ct">Daily sales — ALL tickets (by days to festival) <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>2026 <span class="yl-l" style="background:var(--y25)"></span>2025</span></div><canvas id="c-dall" height="130"></canvas></div>
  <div class="g3">
    <div class="card"><div class="ct">Daily — Saturday <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-dsat" height="190"></canvas></div>
    <div class="card"><div class="ct">Daily — Sunday <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-dsun" height="190"></canvas></div>
    <div class="card"><div class="ct">Daily — Monday <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-dmon" height="190"></canvas></div>
  </div>
</div>

<!-- CUMULATIVE -->
<div class="sec" id="s-cum">
  <div class="g2">
    <div class="card"><div class="ct">Cumul. tickets — ALL <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-ct-all" height="200"></canvas></div>
    <div class="card"><div class="ct">Cumul. revenue — ALL <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-cr-all" height="200"></canvas></div>
    <div class="card"><div class="ct">Cumul. tickets — Saturday <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-ct-sat" height="200"></canvas></div>
    <div class="card"><div class="ct">Cumul. revenue — Saturday <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-cr-sat" height="200"></canvas></div>
    <div class="card"><div class="ct">Cumul. tickets — Sunday <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-ct-sun" height="200"></canvas></div>
    <div class="card"><div class="ct">Cumul. revenue — Sunday <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-cr-sun" height="200"></canvas></div>
    <div class="card"><div class="ct">Cumul. tickets — Monday <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-ct-mon" height="200"></canvas></div>
    <div class="card"><div class="ct">Cumul. revenue — Monday <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>26 <span class="yl-l" style="background:var(--y25)"></span>25</span></div><canvas id="c-cr-mon" height="200"></canvas></div>
  </div>
</div>

<!-- WAVES -->
<div class="sec" id="s-wav">
  <div class="tw"><div class="th">Wave status — tickets sold in current wave vs quota &amp; total capacity (2026)</div><table id="tbl-wav"></table></div>
  <div class="g2">
    <div class="card"><div class="ct">Wave fill % vs quota — 2026</div><canvas id="c-wf" height="210"></canvas></div>
    <div class="card"><div class="ct">Sold in wave vs quota — 2026</div><canvas id="c-wb" height="210"></canvas></div>
  </div>
  <div class="tw"><div class="th">Total capacity overview — all ticket types</div><table id="tbl-cap"></table></div>
</div>

<!-- ATTENDANCE -->
<div class="sec" id="s-att">
  <div class="tw"><div class="th">Attendance projection — 2026 vs 2025</div><table id="tbl-att"></table><div class="note">* Guest counts from JM Pricing sheet: Sat 502, Sun 433, Mon 500. No-show rate: 6%. 2025 attendance figures are actuals.</div></div>
  <div class="g2">
    <div class="card"><div class="ct">Tickets by country — top 10 (2026)</div><canvas id="c-ctr" height="210"></canvas></div>
    <div class="card"><div class="ct">Tickets by point of sale (2026)</div><canvas id="c-pos" height="210"></canvas></div>
  </div>
</div>

<!-- BREAKDOWN -->
<div class="sec" id="s-brk">
  <div class="g3">
    <div class="card"><div class="ct">Saturday — by wave (2026)</div><canvas id="c-bsat" height="210"></canvas></div>
    <div class="card"><div class="ct">Sunday — by wave (2026)</div><canvas id="c-bsun" height="210"></canvas></div>
    <div class="card"><div class="ct">Monday — by wave (2026)</div><canvas id="c-bmon" height="210"></canvas></div>
  </div>
  <div class="g2">
    <div class="card"><div class="ct">Wave split: Presale→ Early Bird→ Regular→ Final Wave <span class="yl"><span class="yl-l" style="background:var(--y26)"></span>2026 <span class="yl-l" style="background:var(--y25)"></span>2025</span></div><canvas id="c-wsplit" height="210"></canvas></div>
    <div class="card"><div class="ct">Ticket type — 2026 now vs 2025 same period</div><canvas id="c-tcomp" height="210"></canvas></div>
  </div>
</div>

</div>

